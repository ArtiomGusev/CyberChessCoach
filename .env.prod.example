# ChessCoach-AI — production environment template for Hetzner deployment.
#
# Usage:
#   cp .env.prod.example .env.prod
#   nano .env.prod         # fill in every CHANGE_ME value
#
# IMPORTANT: .env.prod contains secrets — do NOT commit it to version control.
# It is already listed in .gitignore.
#
# See docs/DEPLOYMENT.md for full variable reference and first-time setup guide.

# ── ENVIRONMENT ───────────────────────────────────────────────────────────────

SECA_ENV=prod

# ── AUTHENTICATION ────────────────────────────────────────────────────────────

# API key for X-Api-Key protected routes (engine eval, debug, etc.).
# Must match COACH_API_KEY baked into the Android release APK.
# Use any non-empty random string; rotate independently of SECRET_KEY.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
SECA_API_KEY=CHANGE_ME

# JWT signing key. Must be ≥ 32 characters and stable across restarts
# (changing it invalidates all active player sessions).
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

# ── CORS ──────────────────────────────────────────────────────────────────────

# Android clients do not send Origin headers (CORS is a browser mechanism),
# so setting '*' is safe for a mobile-only API and silences the server warning.
# Restrict to specific origins if you add a web frontend.
CORS_ALLOWED_ORIGINS=*

# ── DATABASE (PostgreSQL) ─────────────────────────────────────────────────────

# SQLAlchemy connection URL — uses the 'db' service name from docker-compose.prod.yml.
# Replace CHANGE_ME_DB_PASSWORD with the same value as POSTGRES_PASSWORD below.
DATABASE_URL=postgresql://chesscoach:CHANGE_ME_DB_PASSWORD@db:5432/chesscoach

# Postgres container credentials (read by the postgres:16-alpine image).
POSTGRES_DB=chesscoach
POSTGRES_USER=chesscoach
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── LLM / OLLAMA ─────────────────────────────────────────────────────────────

# Ollama runs as a sibling Docker service — reachable by service name.
# Do not change COACH_OLLAMA_URL unless you run Ollama on a separate host.
COACH_OLLAMA_URL=http://ollama:11434
COACH_OLLAMA_MODEL=qwen2.5:7b-instruct-q2_K

# ── ENGINE PERFORMANCE (OPTIONAL) ────────────────────────────────────────────

# ENGINE_POOL_SIZE=8
# ENGINE_THREADS=1
# ENGINE_HASH_MB=128

# ── CACHE (OPTIONAL) ─────────────────────────────────────────────────────────

# Uncomment to enable persistent move cache via Redis.
# Add a 'redis' service to docker-compose.prod.yml if needed.
# REDIS_URL=redis://redis:6379
