<?xml version="1.0" encoding="utf-8"?>
<!--
    Cereveon · Atrium theme.

    Atrium is dark-only by design intent (handoff README "Out of scope:
    Light mode — Cereveon Atrium is dark-only by design intent.").  We
    therefore parent against Theme.Material3.Dark.NoActionBar — not
    DayNight — so the system light-mode toggle never reverts the app
    to a Material default light palette.

    Material 3 colour attributes are remapped onto Atrium tokens so any
    Material component (TextView, Button, BottomSheet, etc.) inherits
    the re-skin without per-widget edits.  Layout files that reference
    @color/atrium_* directly bypass this mapping; layouts that use
    ?attr/colorOnBackground style refs benefit from it automatically.
-->
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ─── Atrium theme ─────────────────────────────────────────────── -->
    <style name="Theme.Cereveon.Atrium" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Surfaces -->
        <item name="android:windowBackground">@drawable/bg_atrium_gradient</item>
        <item name="colorBackground">@color/atrium_bg_base</item>
        <item name="android:colorBackground">@color/atrium_bg_base</item>
        <item name="colorSurface">@color/atrium_bg_surface</item>
        <item name="colorSurfaceVariant">@color/atrium_bg_surface</item>
        <item name="colorSurfaceContainer">@color/atrium_bg_surface</item>
        <item name="colorSurfaceContainerHigh">@color/atrium_bg_surface</item>

        <!-- Ink -->
        <item name="colorOnBackground">@color/atrium_ink</item>
        <item name="colorOnSurface">@color/atrium_ink</item>
        <item name="colorOnSurfaceVariant">@color/atrium_muted</item>
        <item name="android:textColorPrimary">@color/atrium_ink</item>
        <item name="android:textColorSecondary">@color/atrium_muted</item>
        <item name="android:textColorTertiary">@color/atrium_dim</item>
        <item name="android:textColorHint">@color/atrium_dim</item>

        <!-- Accents — neon-only-for-signal -->
        <item name="colorPrimary">@color/atrium_accent_cyan</item>
        <item name="colorOnPrimary">@color/atrium_bg_base</item>
        <item name="colorPrimaryContainer">@color/atrium_bg_surface</item>
        <item name="colorOnPrimaryContainer">@color/atrium_accent_cyan</item>
        <item name="colorSecondary">@color/atrium_accent_amber</item>
        <item name="colorOnSecondary">@color/atrium_bg_base</item>
        <item name="colorTertiary">@color/atrium_accent_amber</item>
        <item name="colorAccent">@color/atrium_accent_cyan</item>

        <!-- Outlines / dividers -->
        <item name="colorOutline">@color/atrium_hairline_strong</item>
        <item name="colorOutlineVariant">@color/atrium_hairline</item>

        <!-- System bars — let the gradient run edge-to-edge.  The board
             header gives enough top contrast that a transparent status
             bar doesn't clash. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/atrium_bg_base</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Default text appearance fallback -->
        <item name="android:textAppearance">@style/Atrium.Body</item>
    </style>

    <!-- Backwards-compat alias.  The pre-Atrium theme name is preserved
         so layouts referencing it (or test fixtures) still resolve. -->
    <style name="Theme.CyberpunkChess" parent="Theme.Cereveon.Atrium" />

    <!-- ─── Atrium TextAppearances ───────────────────────────────────── -->
    <!--
        Five typography roles per the handoff:
          Display title       — Cormorant Garamond italic 500, 28–44sp
          Body / coach prose  — Cormorant Garamond 400, 16–18sp
          UI label / kicker   — JetBrains Mono 500, 8–11sp UPPERCASE
          Numerics            — JetBrains Mono 500, 11–22sp
          Inline UI text      — Inter 400/500, 11–14sp
    -->

    <style name="Atrium.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/cormorant_garamond</item>
        <item name="android:textStyle">italic</item>
        <item name="android:textFontWeight" tools:targetApi="p">500</item>
        <item name="android:textSize">28sp</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
        <item name="android:letterSpacing">0.011</item>      <!-- ≈0.3 / 28sp -->
        <item name="android:textColor">@color/atrium_ink</item>
    </style>

    <style name="Atrium.Display.Large" parent="Atrium.Display">
        <item name="android:textSize">44sp</item>
        <item name="android:lineSpacingMultiplier">1.0</item>
    </style>

    <style name="Atrium.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/cormorant_garamond</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textFontWeight" tools:targetApi="p">400</item>
        <item name="android:textSize">17sp</item>
        <item name="android:lineSpacingMultiplier">1.45</item>
        <item name="android:textColor">@color/atrium_ink</item>
    </style>

    <style name="Atrium.Body.Italic" parent="Atrium.Body">
        <item name="android:textStyle">italic</item>
    </style>

    <style name="Atrium.Kicker" parent="TextAppearance.Material3.LabelSmall">
        <!--
            Mono uppercase kicker.  Letter-spacing 2.0–2.4 in the design
            translates to ~0.222 em at 9sp (Android measures letterSpacing
            as em multiplier, not absolute px).
        -->
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="android:textFontWeight" tools:targetApi="p">500</item>
        <item name="android:textSize">9sp</item>
        <item name="android:letterSpacing">0.222</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/atrium_dim</item>
    </style>

    <style name="Atrium.Kicker.Cyan" parent="Atrium.Kicker">
        <item name="android:textColor">@color/atrium_accent_cyan</item>
    </style>

    <style name="Atrium.Numeric" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="android:textFontWeight" tools:targetApi="p">500</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.045</item>     <!-- ≈0.5 / 11sp -->
        <item name="android:textColor">@color/atrium_ink</item>
    </style>

    <style name="Atrium.Numeric.Cyan" parent="Atrium.Numeric">
        <item name="android:textColor">@color/atrium_accent_cyan</item>
    </style>

    <style name="Atrium.Numeric.Amber" parent="Atrium.Numeric">
        <item name="android:textColor">@color/atrium_accent_amber</item>
    </style>

    <style name="Atrium.Inline" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textFontWeight" tools:targetApi="p">400</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/atrium_muted</item>
    </style>

    <!-- ─── Atrium widget styles ─────────────────────────────────────── -->

    <!--
        Primary action button — italic Cormorant label, cyan border,
        44dp tall, 2dp corners.  Matches the "Ask the coach" / "Begin"
        primary CTAs in the handoff screens.
    -->
    <style name="Atrium.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/btn_atrium_primary</item>
        <item name="backgroundTint">@null</item>
        <item name="android:fontFamily">@font/cormorant_garamond</item>
        <item name="android:textStyle">italic</item>
        <item name="android:textFontWeight" tools:targetApi="p">500</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/atrium_accent_cyan</item>
        <item name="android:minHeight">@dimen/atrium_tap_target</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="cornerRadius">@dimen/atrium_corner_radius</item>
    </style>

    <style name="Atrium.Button.Secondary" parent="Atrium.Button.Primary">
        <item name="android:background">@drawable/btn_atrium_secondary</item>
        <item name="android:textColor">@color/atrium_ink</item>
        <item name="android:textSize">20sp</item>
    </style>

    <!-- Hairline divider used between sections.  Use as
         <View style="@style/Atrium.Divider"/> with layout_height=1dp. -->
    <style name="Atrium.Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/atrium_hairline_thickness</item>
        <item name="android:background">@color/atrium_hairline</item>
    </style>

</resources>
