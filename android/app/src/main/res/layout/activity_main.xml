<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAIN CONTENT -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <!-- CHESS BOARD -->
        <com.example.myapplication.ChessBoardView
            android:id="@+id/chessBoard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"/>

        <!-- COACH DOCK -->
        <LinearLayout
            android:id="@+id/txtCoachContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical">

            <!-- LARGE TRANSPARENT HIT-ZONE -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@android:color/transparent"/>

            <!-- ACTUAL VISIBLE DOCK CONTENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0B0F14"
                android:elevation="8dp">

                <!-- NEON DIVIDER (TOP BORDER) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#00FFFF"
                    android:alpha="0.4"/>

                <!-- DRAG HANDLE -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="#33FFFFFF"
                    android:backgroundTint="#00FFFF"
                    android:alpha="0.3"
                    android:layerType="software"/>

                <!-- NEXT TRAINING CHIP (shown when a curriculum rec is cached) -->
                <TextView
                    android:id="@+id/txtNextTrainingChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#00FF88"
                    android:textSize="11sp"
                    android:typeface="monospace"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    android:background="#1A00FF88"
                    android:visibility="gone"/>

                <!-- SCORE + CATEGORY BADGES (hidden until first AI move) -->
                <LinearLayout
                    android:id="@+id/scoreRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="6dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txtEngineScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#00FFFF"
                        android:textSize="11sp"
                        android:typeface="monospace"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:background="#1A004040"/>

                    <TextView
                        android:id="@+id/txtMistakeCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:layout_marginStart="8dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"/>

                </LinearLayout>

                <!-- STATUS PULSE + COACHING EXPLANATION / FALLBACK -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="40dp">

                    <View
                        android:id="@+id/statusPulse"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/status_dot_green"/>

                    <TextView
                        android:id="@+id/txtCoach"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#00FFFF"
                        android:textSize="14sp"
                        android:layout_marginStart="10dp"
                        android:gravity="center_vertical"
                        android:text="♟ Ready"
                        android:letterSpacing="0.05"
                        android:textAllCaps="true"
                        android:typeface="monospace"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- RIGHT DRAWER (SIDEBAR) -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="#0B0F14"
        android:paddingTop="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="48dp">

        <TextView
            android:id="@+id/txtRatingHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rating: —"
            android:textColor="#00FFFF"
            android:textSize="14sp"
            android:typeface="monospace"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/txtWeaknessTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#888888"
            android:textSize="11sp"
            android:typeface="monospace"
            android:paddingBottom="12dp"
            android:visibility="gone"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GAME OPTIONS"
            android:textColor="#888888"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:paddingBottom="16dp"/>

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="RESET GAME"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1F242A"
            android:textAllCaps="true"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnUndo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="UNDO MOVE"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1F242A"
            android:textAllCaps="true"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#232931"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI ASSISTANCE"
            android:textColor="#888888"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:paddingBottom="16dp"/>

        <Button
            android:id="@+id/btnChat"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="OPEN COACH CHAT"
            android:textColor="#000000"
            android:backgroundTint="#00FFFF"
            android:textAllCaps="true"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnGameHistory"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="GAME HISTORY"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1F242A"
            android:textAllCaps="true"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/btnChangePassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="CHANGE PASSWORD"
            android:textColor="#888888"
            android:backgroundTint="#1F242A"
            android:textAllCaps="true"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="SIGN OUT"
            android:textColor="#FF4444"
            android:backgroundTint="#1F242A"
            android:textAllCaps="true"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CHESS ENGINE v1.0"
            android:textColor="#444444"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingTop="16dp"
            android:typeface="monospace"/>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
