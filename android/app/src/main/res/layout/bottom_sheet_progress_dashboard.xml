<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#0B0F14"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PROGRESS DASHBOARD"
            android:textColor="#00FFFF"
            android:textSize="14sp"
            android:typeface="monospace"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A00FFFF"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"/>

        <!-- ── Rating sparkline ────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RATING TREND"
            android:textColor="#666666"
            android:textSize="11sp"
            android:typeface="monospace"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp"/>

        <com.example.myapplication.RatingSparklineView
            android:id="@+id/progressSparkline"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/txtNoRatingHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Play more games to see your rating trend."
            android:textColor="#444444"
            android:textSize="12sp"
            android:typeface="monospace"
            android:paddingStart="20dp"
            android:paddingBottom="8dp"
            android:visibility="gone"/>

        <!-- ── Rating / confidence row ────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RATING"
                    android:textColor="#666666"
                    android:textSize="10sp"
                    android:typeface="monospace"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/txtRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:typeface="monospace"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONFIDENCE"
                    android:textColor="#666666"
                    android:textSize="10sp"
                    android:typeface="monospace"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/txtConfidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:typeface="monospace"/>

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#0DFFFFFF"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"/>

        <!-- ── Weakness profile ───────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WEAKNESS PROFILE"
            android:textColor="#666666"
            android:textSize="11sp"
            android:typeface="monospace"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <com.example.myapplication.WeaknessBarChartView
            android:id="@+id/weaknessChart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:minHeight="56dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#0DFFFFFF"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"/>

        <!-- ── World model ─────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HOW THE COACH SEES YOU"
            android:textColor="#666666"
            android:textSize="11sp"
            android:typeface="monospace"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <LinearLayout
            android:id="@+id/worldModelContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#0DFFFFFF"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"/>

        <!-- ── Training recommendations ───────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TRAINING FOCUS"
            android:textColor="#666666"
            android:textSize="11sp"
            android:typeface="monospace"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <LinearLayout
            android:id="@+id/recommendationsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"/>

        <TextView
            android:id="@+id/txtNoRecommendations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Play more games to unlock personalised recommendations."
            android:textColor="#444444"
            android:textSize="12sp"
            android:typeface="monospace"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp"
            android:visibility="gone"/>

        <!-- ── Loading / error ────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/txtDashboardError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Could not load dashboard. Check your connection."
            android:textColor="#666666"
            android:textSize="13sp"
            android:typeface="monospace"
            android:gravity="center"
            android:paddingTop="32dp"
            android:paddingBottom="32dp"
            android:visibility="gone"/>

    </LinearLayout>

</ScrollView>
