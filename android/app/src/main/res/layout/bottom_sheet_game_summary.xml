<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0B0F14"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#33FFFFFF"/>

    <!-- Rating row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/txtNewRating"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Rating: —"
            android:textColor="#00FFFF"
            android:textSize="20sp"
            android:typeface="monospace"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtActionBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COACH"
            android:textColor="#000000"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="#00FFFF"/>

    </LinearLayout>

    <!-- Confidence bar -->
    <ProgressBar
        android:id="@+id/progressConfidence"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginBottom="4dp"
        android:progressTint="#00FFFF"
        android:progressBackgroundTint="#1A004040"
        android:max="100"
        android:progress="0"/>

    <TextView
        android:id="@+id/txtConfidenceLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confidence: 0%"
        android:textColor="#888888"
        android:textSize="11sp"
        android:typeface="monospace"
        android:layout_marginBottom="16dp"/>

    <!-- Coach content title -->
    <TextView
        android:id="@+id/txtCoachTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- Coach content description -->
    <TextView
        android:id="@+id/txtCoachDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginBottom="24dp"/>

    <!-- Training card (initially hidden) -->
    <LinearLayout
        android:id="@+id/trainingCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A004040"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/txtTrainingTopic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Topic: —"
            android:textColor="#00FFFF"
            android:textSize="13sp"
            android:typeface="monospace"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/txtTrainingFormat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Format: —"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:typeface="monospace"/>

            <TextView
                android:id="@+id/txtTrainingGain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+0 Elo"
                android:textColor="#00FF88"
                android:textSize="12sp"
                android:typeface="monospace"/>

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressDifficulty"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:progressTint="#00FFFF"
            android:progressBackgroundTint="#1A004040"
            android:max="100"
            android:progress="0"/>

    </LinearLayout>

    <!-- Empty state for training (shown on 404) -->
    <TextView
        android:id="@+id/txtTrainingEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No training recommendation available."
        android:textColor="#555555"
        android:textSize="13sp"
        android:layout_marginBottom="16dp"
        android:visibility="gone"/>

    <!-- Start training button -->
    <Button
        android:id="@+id/btnStartTraining"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="START TRAINING"
        android:textColor="#000000"
        android:backgroundTint="#00FFFF"
        android:textAllCaps="true"
        android:insetTop="0dp"
        android:insetBottom="0dp"/>

</LinearLayout>
