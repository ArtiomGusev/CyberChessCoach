FROM python:3.14-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends stockfish \
    && useradd --create-home --uid 10001 appuser \
    && rm -rf /var/lib/apt/lists/*

# copy requirements from llm folder
COPY llm/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

# copy only llm code
COPY llm /app/llm
RUN rm -rf /app/llm/tests /app/llm/rag/tests /app/llm/.github /app/llm/redis-win \
    && rm -f /app/llm/package.json /app/llm/package-lock.json /app/llm/server.js /app/llm/test.js /app/llm/test_mixed.js /app/llm/test_unique_fens.js \
    && mkdir -p /app/data \
    && chown -R appuser:appuser /app

USER appuser

ENV PYTHONPATH=/app

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 CMD python -c "import sys, urllib.request; sys.exit(0 if urllib.request.urlopen('http://127.0.0.1:8000/health', timeout=4).status == 200 else 1)"

CMD ["uvicorn", "llm.server:app", "--host", "0.0.0.0", "--port", "8000"]
