# Copy this file to .env and fill in the values.
# docker-compose and the Python server both load .env automatically.

# ── REQUIRED ────────────────────────────────────────────────────────────────

# API authentication key. In dev mode any non-empty string works.
SECA_API_KEY=dev-key

# Runtime environment. Use "dev" locally, "prod" in production.
# "prod" enforces JWT auth and disables debug output.
SECA_ENV=dev

# ── STOCKFISH ENGINE ─────────────────────────────────────────────────────────

# Path to the Stockfish binary. Leave unset to use auto-detection.
# The server checks PATH first (shutil.which), then falls back to the OS default.
#
#   Linux system install:  /usr/games/stockfish  or  /usr/bin/stockfish
#   macOS Homebrew:        /opt/homebrew/bin/stockfish
#   Windows:               engines/stockfish.exe  (place binary in project root)
#   Docker:                /usr/games/stockfish   (installed via apt at build time)
#
# STOCKFISH_PATH=

# ── LLM / OLLAMA ─────────────────────────────────────────────────────────────

# URL of the running Ollama server.
# Docker Compose: host.docker.internal works on macOS, Windows, and Linux (via extra_hosts).
# Bare-metal:     use http://localhost:11434
COACH_OLLAMA_URL=http://host.docker.internal:11434

# Ollama model to use for chess explanations.
COACH_OLLAMA_MODEL=qwen2.5:7b-instruct-q2_K

# ── CACHE (OPTIONAL) ─────────────────────────────────────────────────────────

# Redis URL for persistent move cache. Omit to use in-memory cache only.
# REDIS_URL=redis://localhost:6379

# ── SERVER ───────────────────────────────────────────────────────────────────

# HOST=0.0.0.0
# PORT=8000
# UVICORN_WORKERS=4

# ── ENGINE PERFORMANCE (OPTIONAL OVERRIDES) ──────────────────────────────────

# ENGINE_POOL_SIZE=8
# ENGINE_THREADS=1
# ENGINE_HASH_MB=128
# ENGINE_SKILL_LEVEL=10
# ENGINE_DEFAULT_MOVETIME_MS=40
# ENGINE_BLITZ_MOVETIME_MS=25
# ENGINE_ANALYSIS_MOVETIME_MS=80
